# 3. VIDEO RECORDER
# ══════════════════════════════════════════════════════════════════════════════

class VideoRecorder:
    """
    Captures MuJoCo offscreen frames at VIDEO_FPS and assembles them into an
    MP4 at the end of the simulation.

    Usage
    ─────
      recorder = VideoRecorder(model, data)
      # call once per physics step (internally skips frames to hit VIDEO_FPS)
      recorder.tick(sim_time_relative)
      # at the end:
      path = recorder.save("/tmp/grasp.mp4")
      recorder.preview_and_prompt(path)
    """

    def __init__(self, model, data):
        self._model    = model
        self._data     = data
        self._renderer = mujoco.Renderer(model, height=VIDEO_HEIGHT, width=VIDEO_WIDTH)

        # Camera: match the old passive-viewer default
        self._cam           = mujoco.MjvCamera()
        self._cam.lookat[:] = [0.2, 0.0, 0.2]
        self._cam.distance  = 0.8
        self._cam.elevation = -20.0
        self._cam.azimuth   = 90.0

        self._opt = mujoco.MjvOption()
        self._opt.flags[mujoco.mjtVisFlag.mjVIS_CONTACTPOINT] = True
        self._opt.flags[mujoco.mjtVisFlag.mjVIS_CONTACTFORCE] = True
        model.vis.map.force = 0.03

        self._frame_interval = 1.0 / VIDEO_FPS   # seconds between captured frames
        self._next_frame_t   = 0.0               # next relative time to capture
        self._frames: list[np.ndarray] = []       # RGB uint8 frames

    # ── Frame capture ──────────────────────────────────────────────────────────

    def tick(self, t_rel: float) -> None:
        """Call after every mj_step.  Captures a frame when due."""
        if t_rel < self._next_frame_t:
            return
        self._next_frame_t = t_rel + self._frame_interval

        self._renderer.update_scene(self._data, camera=self._cam, scene_option=self._opt)
        frame = self._renderer.render()          # returns (H, W, 3) RGB uint8
        self._frames.append(frame.copy())

    # ── Save ──────────────────────────────────────────────────────────────────

    def save(self, path: str) -> str:
        """Write captured frames to an MP4 file.  Returns the path."""
        if not self._frames:
            rospy.logwarn("VideoRecorder: no frames captured — skipping save.")
            return path

        fourcc = cv2.VideoWriter_fourcc(*"mp4v")
        writer = cv2.VideoWriter(path, fourcc, VIDEO_FPS,
                                 (VIDEO_WIDTH, VIDEO_HEIGHT))
        for frame in self._frames:
            writer.write(cv2.cvtColor(frame, cv2.COLOR_RGB2BGR))
        writer.release()
        rospy.loginfo("VideoRecorder: %d frames saved to %s", len(self._frames), path)
        return path

    # ── Preview + save prompt ─────────────────────────────────────────────────

    def preview_and_prompt(self, path: str) -> None:
        """
        Play the full recording in an OpenCV window at VIDEO_FPS, then ask
        whether to keep the saved file.  Press any key to skip ahead; close
        the window or wait for the video to finish before the prompt appears.
        The MP4 is always written to `path` first; if the user declines it is
        deleted.
        """
        if not self._frames:
            return

        frame_ms = max(1, round(1000 / VIDEO_FPS))   # ms per frame for waitKey

        cv2.namedWindow("Simulation recording", cv2.WINDOW_NORMAL)
        cv2.resizeWindow("Simulation recording", VIDEO_WIDTH, VIDEO_HEIGHT)

        for frame in self._frames:
            bgr = cv2.cvtColor(frame, cv2.COLOR_RGB2BGR)
            cv2.imshow("Simulation recording", bgr)
            key = cv2.waitKey(frame_ms)
            if key == ord("q") or cv2.getWindowProperty(
                "Simulation recording", cv2.WND_PROP_VISIBLE
            ) < 1:
                break   # user closed the window or pressed q

        cv2.destroyAllWindows()

        answer = input(f"\nSave video to '{path}'? [y/N] ").strip().lower()
        if answer in ("y", "yes"):
            rospy.loginfo("Video kept at: %s", path)
        else:
            try:
                os.remove(path)
                rospy.loginfo("Video discarded.")
            except FileNotFoundError:
                pass


