# 5. ROS NODE
# ══════════════════════════════════════════════════════════════════════════════

class ShadowHandDigitalTwin:
    """
    Headless MuJoCo digital twin — step-locked, faster than real-time.

    Threading model
    ───────────────
      Main thread : physics loop — blocks on _cmd_event, advances CTRL_DT of
                    physics per command, then publishes joint state immediately.
      ROS spin    : rospy.spin() in a daemon thread; _command_callback writes
                    to _ctrl_buffer and sets _cmd_event under _ctrl_lock.
    """

    def __init__(self):
        # ── ROS init ──────────────────────────────────────────────────────────
        rospy.init_node("shadow_hand_digital_twin", anonymous=False)

        self._state_pub = rospy.Publisher(
            "/shadowhand_state_topic",
            JointState,
            queue_size=1,
        )

        # Command subscriber — callback writes buffer and signals the physics loop
        self._ctrl_lock   = threading.Lock()
        self._ctrl_buffer = None          # None until first command arrives
        self._cmd_event   = threading.Event()   # set each time a new command arrives
        self._cmd_sub = rospy.Subscriber(
            "/shadowhand_command_topic",
            Float64MultiArray,
            self._command_callback,
            queue_size=1,
        )

        # Lift state (no external trigger — driven by timeline)
        self._lift_active  = False
        self._lift_target  = 0.2          # m — tune to your scene
        self._lift_current = INITIAL_CONFIG["rh_arm_lift"]
        self._lift_speed   = 0.05         # m/s ramp rate

        # Timeline: set once when the first command is received
        self._first_cmd_sim_time: float | None = None

        # ── MuJoCo model ──────────────────────────────────────────────────────
        _ROS_PACK   = rospkg.RosPack()
        _MODEL_PATH = os.path.join(
            _ROS_PACK.get_path("my_package"),
            "mjcf", "shadow_hand", "scene_right_perso.xml"
        )
        # _MODEL_PATH = os.path.join(
        #     _ROS_PACK.get_path("my_package"),
        #     "mjcf", "shadow_hand", "scene_lateral_pinch.xml"
        # )

        self._model = mujoco.MjModel.from_xml_path(_MODEL_PATH)
        self._data  = mujoco.MjData(self._model)

        self._coupled   = detect_coupling_mode(self._model)
        _mode_label     = "coupled (J0 tendon)" if self._coupled else "uncoupled (per-joint)"
        rospy.loginfo("Coupling mode detected: %s", _mode_label)

        _actuator_names = (
            ALL_ACTUATOR_NAMES_COUPLED if self._coupled else ALL_ACTUATOR_NAMES_UNCOUPLED
        )
        self._joint_qpos_ids, self._joint_qvel_ids, self._actuator_ids = (
            build_index_maps(self._model, _actuator_names)
        )

        apply_initial_config(
            self._model, self._data, INITIAL_CONFIG, self._actuator_ids, self._coupled
        )

        # ── Grasp logger (always on) ───────────────────────────────────────────
        self._logger = GraspLogger(
            self._model, self._data,
            JOINT_NAMES, self._joint_qpos_ids, self._actuator_ids,
        )

        # ── Video recorder (always on) ─────────────────────────────────────────
        self._video = VideoRecorder(self._model, self._data)

        # ── ROS spin thread ───────────────────────────────────────────────────
        self._stop_event  = threading.Event()
        self._spin_thread = threading.Thread(target=rospy.spin, daemon=True)
        self._spin_thread.start()

        rospy.loginfo(
            "Shadow Hand digital twin initialised — headless step-locked mode.\n"
            "  CTRL_DT=%.4f s  LIFT_TIME=%.1f s  SIM_STOP_TIME=%.1f s",
            CTRL_DT, LIFT_TIME, SIM_STOP_TIME,
        )

    # ── ROS subscriber callback ────────────────────────────────────────────────

    def _command_callback(self, msg: Float64MultiArray):
        """
        Receives 24 joint targets, maps them to MuJoCo ctrl indices, then
        signals the physics loop that a new command is ready.
        """
        if len(msg.data) != len(JOINT_NAMES):
            rospy.logwarn_throttle(
                5.0,
                f"Command message: expected {len(JOINT_NAMES)} values, "
                f"got {len(msg.data)}.",
            )
            return

        cmd  = {name: float(msg.data[i]) for i, name in enumerate(JOINT_NAMES)}
        ctrl = np.zeros(self._model.nu)

        if self._coupled:
            for joint_name in JOINT_NAMES:
                actuator_name = joint_name.replace("rh_", "rh_A_")
                if actuator_name in self._actuator_ids:
                    ctrl[self._actuator_ids[actuator_name]] = cmd[joint_name]
            for actuator_name, (j2_name, j1_name) in COUPLED_JOINTS.items():
                ctrl[self._actuator_ids[actuator_name]] = cmd[j2_name] + cmd[j1_name]
        else:
            for joint_name in JOINT_NAMES:
                actuator_name = joint_name.replace("rh_", "rh_A_")
                if actuator_name in self._actuator_ids:
                    ctrl[self._actuator_ids[actuator_name]] = cmd[joint_name]

        with self._ctrl_lock:
            # Record sim time of the very first command (safe: physics loop does
            # not write data.time; the read is at most one step stale).
            if self._first_cmd_sim_time is None:
                self._first_cmd_sim_time = float(self._data.time)
                rospy.loginfo(
                    "First command received at sim time %.4f s — starting timeline.",
                    self._first_cmd_sim_time,
                )
                self._logger.set_time_origin(self._first_cmd_sim_time)
            self._ctrl_buffer = ctrl

        self._cmd_event.set()

    # ── Publisher helper ───────────────────────────────────────────────────────

    def _publish_state(self):
        msg              = JointState()
        msg.header.stamp = rospy.Time.now()
        msg.name         = JOINT_NAMES
        msg.position     = [float(self._data.qpos[i]) for i in self._joint_qpos_ids]
        msg.velocity     = [float(self._data.qvel[i]) for i in self._joint_qvel_ids]
        self._state_pub.publish(msg)

    # ── Main physics loop ──────────────────────────────────────────────────────

    def run(self):
        """
        Step-locked headless loop.

        Phase 1 — IDLE (before first command)
        ──────────────────────────────────────
          Publishes the initial joint state at IDLE_HZ so Julia can prime its
          state estimate.  Blocks on _cmd_event with a 1/IDLE_HZ timeout and
          re-publishes on each timeout.  Exits this phase permanently as soon
          as the first command is received — the loop never returns here.

        Phase 2 — ACTIVE (first command received onwards)
        ──────────────────────────────────────────────────
          Blocks on _cmd_event with no timeout — as fast as Julia can send.
          Per command:
            1. Snapshot ctrl buffer.
            2. Advance physics by exactly CTRL_DT seconds (multiple mj_step calls).
            3. Apply timeline: lift at LIFT_TIME, stop at SIM_STOP_TIME.
            4. Log data and capture video frame.
            5. Publish resulting joint state.
        """
        dt            = self._model.opt.timestep        # e.g. 0.002 s
        steps_per_cmd = max(1, round(CTRL_DT / dt))     # physics steps per command
        idle_timeout  = 1.0 / IDLE_HZ

        rospy.loginfo(
            "Physics dt=%.4f s | CTRL_DT=%.4f s | %d steps per command.",
            dt, CTRL_DT, steps_per_cmd,
        )

        try:
            # ── Phase 1: IDLE ─────────────────────────────────────────────────
            rospy.loginfo("IDLE — publishing initial state at %d Hz, waiting for first command.", IDLE_HZ)
            while not self._stop_event.is_set() and not rospy.is_shutdown():
                self._cmd_event.wait(timeout=idle_timeout)
                self._cmd_event.clear()

                with self._ctrl_lock:
                    first_cmd_sim_time = self._first_cmd_sim_time

                if first_cmd_sim_time is not None:
                    break   # first command received — exit idle permanently

                self._publish_state()   # heartbeat: no command yet

            # ── Phase 2: ACTIVE ───────────────────────────────────────────────
            rospy.loginfo("ACTIVE — step-locked physics loop started.")
            self._publish_state()   # publish initial state at the moment the first command is received
            while not self._stop_event.is_set() and not rospy.is_shutdown():
                # Block until Julia sends the next command (no timeout)
                self._cmd_event.wait()
                self._cmd_event.clear()

                with self._ctrl_lock:
                    ctrl_snapshot      = self._ctrl_buffer
                    first_cmd_sim_time = self._first_cmd_sim_time

                # Advance physics by CTRL_DT ───────────────────────────────────
                np.copyto(self._data.ctrl, ctrl_snapshot)

                lift_aid = self._actuator_ids["rh_A_arm_lift"]
                for _ in range(steps_per_cmd):
                    if self._lift_active and self._lift_current < self._lift_target:
                        self._lift_current = min(
                            self._lift_current + self._lift_speed * dt,
                            self._lift_target,
                        )
                    self._data.ctrl[lift_aid] = self._lift_current
                    mujoco.mj_step(self._model, self._data)
                    self._logger.record()

                # Timeline orchestration ───────────────────────────────────────
                t_rel = self._data.time - first_cmd_sim_time

                if not self._lift_active and t_rel >= LIFT_TIME:
                    rospy.loginfo("Timeline: lifting at t_rel=%.2f s.", t_rel)
                    self._lift_active = True

                self._video.tick(t_rel)

                if t_rel >= SIM_STOP_TIME:
                    rospy.loginfo("Timeline: SIM_STOP_TIME reached (%.1f s) — stopping.", t_rel)
                    self._stop_event.set()

                # Publish resulting state ──────────────────────────────────────
                self._publish_state()

        except KeyboardInterrupt:
            rospy.loginfo("Physics loop interrupted by user.")
        finally:
            self._stop_event.set()
            rospy.loginfo("Digital twin stopped.")


