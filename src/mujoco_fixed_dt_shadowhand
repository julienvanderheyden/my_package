# Duration of each simulation burst per received command (s).
# Must match the fixed dt used on the Julia side (1 / 125 Hz).
CTRL_DT: float = 1.0 / 125.0          # 8 ms

# Relative time (s after first command) at which the arm lift is triggered.
LIFT_TIME: float = 20.0

# Relative time (s after first command) at which the simulation stops.
SIM_STOP_TIME: float = 40.0

# Publishing rate for the idle heartbeat (before first command arrives).
IDLE_HZ: int = 10

# Video recording
VIDEO_FPS: int   = 30                 # frame rate of the output video
VIDEO_WIDTH: int  = 640           # offscreen render width  (px)
VIDEO_HEIGHT: int = 480           # offscreen render height (px)



